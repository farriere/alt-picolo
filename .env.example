# Paste your Google Sheet ID or full URL here.
# The sheet must be publicly readable (File > Share > Anyone with the link > Viewer).
# Column A = prompt text, Column B = category
# Use [1], [2], etc. in prompts to reference random player names.
VITE_GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── S3 deployment (used by scripts/deploy.sh) ─────────────────────────────
# Copy relevant vars into your shell or CI environment before running `npm run deploy`.
# Do NOT commit a filled-in .env file — it is git-ignored.

S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
# AWS_PROFILE=my-profile          # optional: named AWS CLI profile
# CLOUDFRONT_DIST_ID=EXXXXXXXXX   # optional: triggers a cache invalidation
